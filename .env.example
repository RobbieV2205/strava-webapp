# Strava API credentials
# Get these from: https://www.strava.com/settings/api

STRAVA_CLIENT_ID=  # STRAVA CLIENT ID HERE #
STRAVA_CLIENT_SECRET= # STRAVA CLIENT SECRET HERE #

# OAuth2 redirect URI — must match what you set in the Strava API settings
STRAVA_REDIRECT_URI=http://localhost:8080/callback

# Where to cache the OAuth2 tokens between runs
STRAVA_TOKEN_FILE=strava_tokens.json

# Base output directory (a timestamped subfolder is created per run)
OUTPUT_DIR=output

# MySQL connection — used by strava_to_mysql.py
MYSQL_HOST=# YOUR MYSQL HOST IPV4 HERE #
MYSQL_PORT=3306
MYSQL_DATABASE=strava_data

# Root credentials — only needed to create the database and user (first run)
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=# YOUR SQL ROOT PASSWORD HERE #

# Application user — gets limited privileges on strava_data only
MYSQL_USER=strava_user
MYSQL_PASSWORD=# YOUR SQL USER PASSWORD HERE #
